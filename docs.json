{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Dimension AI",
  "colors": {
    "primary": "#6b62f2",
    "light": "#8081f9",
    "dark": "#533be5"
  },
  "fonts": {
    "family": "DM Sans"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "search": {
    "prompt": "Search docs..."
  },
  "background": {
    "decoration": "gradient"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "mcp"
    ]
  },
  "seo": {
    "indexing": "all"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "faq"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "chat",
              "artifacts",
              "workflows",
              "skills"
            ]
          },
          {
            "group": "Productivity",
            "pages": [
              "proactive-features"
            ]
          },
          {
            "group": "Extend",
            "pages": [
              "integrations",
              "custom-mcp"
            ]
          },
          {
            "group": "Trust & Safety",
            "pages": [
              "security"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "New Chat",
          "href": "https://dimension.dev/chat/new",
          "icon": "message-plus"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href": "https://status.dimension.dev"
      },
      {
        "label": "Support",
        "href": "mailto:support@dimension.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://dimension.dev"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/joindimension",
      "github": "https://github.com/dimensionhq"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          {
            "label": "Open App",
            "href": "https://dimension.dev"
          },
          {
            "label": "Download",
            "href": "https://dimension.dev/download"
          }
        ]
      },
      {
        "header": "Resources",
        "items": [
          {
            "label": "Support",
            "href": "mailto:support@dimension.dev"
          },
          {
            "label": "Security",
            "href": "/security"
          },
          {
            "label": "Status",
            "href": "https://status.dimension.dev"
          }
        ]
      }
    ]
  }
}
